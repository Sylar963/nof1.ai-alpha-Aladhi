# =============================================================================
# nof1.ai-alpha — environment template
# Copy this file to .env and fill in the values. .env is gitignored.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM (OpenRouter)
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REFERER=
OPENROUTER_APP_TITLE=trading-agent
LLM_MODEL=x-ai/grok-4
# Output token cap for the perps decision call (x-ai/grok-4 supports up to ~128K)
LLM_MAX_TOKENS=16384
# Options agent needs more headroom than perps — vol surface analysis,
# multi-leg legs[] arrays, greeks math, regime classification all push output up.
OPTIONS_LLM_MAX_TOKENS=32768
REASONING_ENABLED=false
REASONING_EFFORT=high

# -----------------------------------------------------------------------------
# Market data
# -----------------------------------------------------------------------------
TAAPI_API_KEY=

# -----------------------------------------------------------------------------
# Hyperliquid (perps venue — used for delta-hedging Thalex options)
# -----------------------------------------------------------------------------
# Provide either HYPERLIQUID_PRIVATE_KEY or MNEMONIC, not both.
HYPERLIQUID_PRIVATE_KEY=
MNEMONIC=
HYPERLIQUID_NETWORK=mainnet            # mainnet | testnet
# Optional override; normally leave blank and use HYPERLIQUID_NETWORK.
HYPERLIQUID_BASE_URL=

# -----------------------------------------------------------------------------
# Thalex (options venue — BTC options only for v1)
# -----------------------------------------------------------------------------
# Auth: JWT RS512 signed with an RSA private key generated in the Thalex UI.
# Steps:
#   1. Log into Thalex (start with TESTNET: https://testnet.thalex.com)
#   2. Account → API Keys → Create new key
#   3. Thalex generates an RSA keypair. SAVE the private key — they only show it once.
#   4. Save the private key as a .pem file at the path below.
#   5. Copy the Key ID (kid) into THALEX_KEY_ID.
#   6. Enable permissions: read + trade. Leave withdraw OFF.
#
THALEX_NETWORK=test                    # test | prod (start on test!)
THALEX_KEY_ID=                         # the "kid" from the Thalex UI
THALEX_PRIVATE_KEY_PATH=./secrets/thalex_private.pem
# Optional - only if you use sub-accounts.
THALEX_ACCOUNT=

# Risk caps for Thalex options trading
THALEX_MAX_CONTRACTS_PER_TRADE=0.1
THALEX_MAX_OPEN_POSITIONS=3
THALEX_UNDERLYINGS=BTC                 # comma-separated; v1 = BTC only

# Delta-hedge threshold (BTC). The event-driven hedger only re-trades the
# perp leg when |target_perp_delta - current_perp_delta| exceeds this value.
# Smaller = catches more pullbacks but more perp fees. Larger = cheaper but
# more naked drift between rebalances. 0.02 is a good default for v1.
THALEX_DELTA_THRESHOLD=0.02

# --- Options Scheduler ---
# Set to 1 to enable the two-cadence options loop alongside the 5m perps loop.
# When enabled, the bot runs a 15m vol surface refresh and a 3h options
# decision cycle via the OptionsAgent (separate LLM pipeline).
# OPTIONS_SCHEDULER_ENABLED=0
# Vol surface refresh interval in seconds (default: 900 = 15 min)
# OPTIONS_VOL_SURFACE_INTERVAL_SECONDS=900
# Options decision cycle interval in seconds (default: 10800 = 3 hours)
# OPTIONS_DECISION_INTERVAL_SECONDS=10800
# Hedge-margin safety buffer multiplier applied to contracts x spot when
# pre-flighting HL free margin for a delta-hedged options trade. 1.25 = refuse
# unless HL has 25% more free margin than the bare hedge would cost.
# OPTIONS_HEDGE_MARGIN_BUFFER_PCT=1.25

# --- Options Structure Layer (Phase 1) ---
# Enable structure classifier + DB persistence + GUI grouping.
# When 0 (default): positions are flat leg lists as before; classifier still
# runs but nothing is persisted and GUI shows the legacy view.
# When 1: each options cycle classifies positions into typed structures
# (credit/debit spreads, ICs, etc.), persists to option_structure_snapshots,
# and the GUI groups Thalex legs by structure_id.
# OPTIONS_STRUCTURE_LAYER=0


# --- Options Structure-Centric Prompt (Phase 2) ---
# Requires OPTIONS_STRUCTURE_LAYER=1 to be useful.
# When 0 (default): LLM prompt unchanged — OptionsContext.to_dict() excludes
# the new structure_views and triggered_by_events fields.
# When 1: OptionsContext.to_dict() emits a "structures" key with the
# LLM-facing StructureView projection (typed structure, days_open, breach,
# P&L, leg detail), and a "triggered_by_events" key (always empty until
# Phase 3 wires the event bus). Targeted prompt regions then reference
# these structures for position management and mispricing ranking.
# OPTIONS_STRUCTURE_PROMPT=0

# --- Options Event Bus ---
# Enable event-driven triggers (Phase 3). Falls back to 3-hour cron when 0.
# OPTIONS_EVENT_BUS_ENABLED=0
# Safety-net heartbeat interval (seconds, default 10800 = 3h)
# OPTIONS_HEARTBEAT_SEC=10800
# Portfolio delta-band trigger (absolute BTC, default 0.10)
# OPTIONS_DELTA_BAND_BTC=0.10
# DTE threshold trigger (days, default 2)
# OPTIONS_DTE_TRIGGER_DAYS=2
# Mispricing score trigger (0.0-1.0, default 0.85)
# OPTIONS_MISPRICING_TRIGGER_SCORE=0.85
# Event source poll interval (seconds, default 30)
# OPTIONS_EVENT_POLL_SECONDS=30

# --- Failed trade retry ---
# Failed trade proposals stay in the Recommendations UI so the user can Retry
# (e.g. after depositing margin) without rebooting. After this many seconds
# they are auto-pruned so stale proposals don't retry against fresh prices.
# Set to 0 to keep failed proposals indefinitely (they can still be dismissed).
# FAILED_PROPOSAL_TTL_SECONDS=1800

# --- Circuit breaker ---
# Auto-pauses the trading loop (via bot_engine.resume_trading to clear) when
# either threshold is breached. Manual resume via UI "Resume Trading" button
# or programmatically via bot_service.resume_trading().
# Set either to 0 to disable that leg of the breaker.
# CIRCUIT_BREAKER_CONSECUTIVE_FAILS=3
# CIRCUIT_BREAKER_DRAWDOWN_PCT=5.0

# -----------------------------------------------------------------------------
# Risk engine (enforced in code, not just prompt)
# -----------------------------------------------------------------------------
# Max loss at sl_price as % of account value per trade; oversized allocations
# are clamped down. 0 disables.
# MAX_RISK_PER_TRADE_PCT=1.0
# Max total Hyperliquid gross notional as a multiple of account value.
# BTC/ETH/SOL exposure all counts toward the same cap. 0 disables.
# MAX_GROSS_LEVERAGE=3.0
# Daily loss limit (% from UTC-day start value); trips the circuit breaker.
# Persisted in data/risk_state.json so restarts don't reset it. 0 disables.
# MAX_DAILY_LOSS_PCT=5.0
# Pending proposals expire after this many seconds (manual mode). 0 disables.
# PROPOSAL_TTL_SECONDS=900
# Refuse to execute an approved proposal if price drifted more than this %
# from proposal-time price. 0 disables.
# PROPOSAL_MAX_PRICE_DRIFT_PCT=1.0

# -----------------------------------------------------------------------------
# Execution quality
# -----------------------------------------------------------------------------
# Hyperliquid market-order slippage tolerance (fraction, default 0.005 = 50bps)
# HL_MAX_SLIPPAGE=0.005
# Funding/OI/volume snapshot cache TTL in seconds (was frozen forever before)
# HL_META_CACHE_TTL_SECONDS=60
# Thalex limit pricing: fraction of the half-spread paid through mid
# (0 = rest at mid, 1 = pay up to the touch)
# THALEX_CROSS_FRACTION=0.25
# Minimum net credit (USD) required before submitting a credit spread
# OPTIONS_MIN_NET_CREDIT_USD=0.0
# Seconds to wait for multi-leg fills before cancelling and unwinding
# OPTIONS_FILL_TIMEOUT_SECONDS=30
# Haircut (IV bps) subtracted from cross-venue mispricing edge when
# executable quotes are unavailable
# MISPRICING_COST_HAIRCUT_BPS=25.0

# -----------------------------------------------------------------------------
# Delta hedge safety caps
# -----------------------------------------------------------------------------
# HEDGE_COOLDOWN_SECONDS=30
# HEDGE_MIN_NOTIONAL_USD=10.0
# HEDGE_MAX_ORDER_NOTIONAL_USD=50000.0

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
ASSETS=BTC,ETH,SOL                     # universe the LLM scans
INTERVAL=15m                           # decision cadence
# Higher-timeframe frame for the LLM's "long_term" indicators. Separate from
# INTERVAL (loop cadence) — the two were previously one variable, which made
# the higher-timeframe context silently collapse to the loop timeframe.
# ANALYSIS_INTERVAL=4h
TRADING_MODE=auto                      # manual | auto

# -----------------------------------------------------------------------------
# LLM tuning
# -----------------------------------------------------------------------------
# Sampling temperature for perps decisions (low = consistent policy)
# LLM_TEMPERATURE=0.2
# HTTP timeout for perps LLM calls in seconds
# LLM_TIMEOUT_SECONDS=180
# Fallback model used to sanitize malformed LLM output
# SANITIZE_MODEL=openai/gpt-5

# -----------------------------------------------------------------------------
# API server
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
APP_PORT=3000
